#!/usr/bin/env python3
"""
Wave-Haven Unified CLI - v2.0
统一命令行工具：管理 Wave 和 Haven 系统
Version: 2.0.0 - 新增 Wave 任务管理
"""

import sys
import os
import json
import argparse
from pathlib import Path
from datetime import datetime, timedelta

# 导入 Wave 模型
try:
    from wave_model import Wave, WaveManager, WaveStatus, WavePriority
except ImportError:
    # 如果导入失败，添加路径
    sys.path.insert(0, str(Path(__file__).parent))
    from wave_model import Wave, WaveManager, WaveStatus, WavePriority

# 配置路径
CONFIG_PATH = Path.home() / ".openclaw/config/wave-haven.yaml"
WAVE_DIR = Path.home() / ".openclaw/shared/SYSTEM/waves"
HAVEN_DIR = Path.home() / ".openclaw/shared/SYSTEM/tagmemo"
EVENTS_DIR = Path.home() / ".openclaw/shared/SYSTEM/events"

# 初始化 WaveManager
wave_manager = WaveManager()

def get_wave_status():
    """获取 Wave 系统状态"""
    try:
        stats = wave_manager.get_stats()
        return {
            'active_waves': stats.get('running', 0),
            'total_waves': stats.get('total', 0),
            'agents': ['Nova', 'Luna', 'Kiki', 'Coco', 'DreamNova'],
            'pending_events': stats.get('pending', 0)
        }
    except Exception as e:
        return {'active_waves': 0, 'total_waves': 0, 'agents': [], 'pending_events': 0}

def get_haven_status():
    """获取 Haven 系统状态"""
    try:
        total_memories = 0
        storage_size = 0
        
        if HAVEN_DIR.exists():
            tag_files = list(HAVEN_DIR.rglob("*.json"))
            total_memories = len(tag_files)
            for f in tag_files:
                storage_size += f.stat().st_size
        
        return {
            'total_memories': total_memories,
            'storage_size': storage_size / (1024 * 1024),
            'recent_queries': 0,
            'last_optimized': 'Never'
        }
    except:
        return {'total_memories': 0, 'storage_size': 0, 'recent_queries': 0, 'last_optimized': 'Unknown'}

def cmd_status(args):
    """状态命令"""
    wave = get_wave_status()
    haven = get_haven_status()
    
    if args.json:
        print(json.dumps({
            "timestamp": datetime.now().isoformat(),
            "wave": wave,
            "haven": haven
        }, indent=2, ensure_ascii=False))
        return
    
    print("=" * 50)
    print("🌊 Wave-Haven System Status")
    print("=" * 50)
    print()
    print("🌊 Wave System (浪潮系统)")
    print(f"  Active Waves:   {wave['active_waves']}")
    print(f"  Total Waves:    {wave['total_waves']}")
    print(f"  Active Agents:  {', '.join(wave['agents'])}")
    print(f"  Pending Events: {wave['pending_events']}")
    print()
    print("🏝️ Haven System (归藏系统)")
    print(f"  Total Memories: {haven['total_memories']}")
    print(f"  Storage Size:   {haven['storage_size']:.1f} MB")
    print(f"  Recent Queries: {haven['recent_queries']}/min")
    print()
    print(f"Last Updated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("=" * 50)

# ============ Wave 命令 ============
def cmd_wave_create(args):
    """创建 Wave"""
    agents = args.agents.split(',') if args.agents else ['nova']
    
    # 解析 deadline
    deadline = None
    if args.deadline:
        try:
            deadline = datetime.fromisoformat(args.deadline)
        except:
            print(f"⚠️ Invalid deadline format. Use ISO format: 2026-03-10T23:59:00")
            return
    
    wave = wave_manager.create_wave(
        name=args.name,
        description=args.description or "",
        agents=agents,
        priority=args.priority,
        deadline=deadline
    )
    
    print(f"✅ Wave created successfully!")
    print()
    print(f"🌊 {wave.id}: {wave.name}")
    print(f"   Status: {wave.get_status_icon()} {wave.status.value}")
    print(f"   Priority: {wave.get_priority_icon()} {wave.priority.value}")
    print(f"   Agents: {', '.join(wave.agents)}")
    if wave.deadline:
        print(f"   Deadline: {wave.deadline.strftime('%Y-%m-%d %H:%M')}")

def cmd_wave_list(args):
    """列出 Waves"""
    status_filter = None
    if args.status:
        try:
            status_filter = WaveStatus(args.status)
        except:
            pass
    
    waves = wave_manager.list_waves(status=status_filter, agent=args.agent, limit=args.limit)
    
    if not waves:
        print("📭 No waves found.")
        return
    
    # 打印表格
    print("┌" + "─" * 8 + "┬" + "─" * 20 + "┬" + "─" * 10 + "┬" + "─" * 15 + "┬" + "─" * 10 + "┐")
    print(f"│{'ID':^8}│{'Name':^20}│{'Status':^10}│{'Agents':^15}│{'Progress':^10}│")
    print("├" + "─" * 8 + "┼" + "─" * 20 + "┼" + "─" * 10 + "┼" + "─" * 15 + "┼" + "─" * 10 + "┤")
    
    for wave in waves:
        name = wave.name[:18] + ".." if len(wave.name) > 20 else wave.name
        agents = ", ".join(wave.agents)[:13] + ".." if len(", ".join(wave.agents)) > 15 else ", ".join(wave.agents)
        print(f"│{wave.id:^8}│{name:20}│{wave.get_status_icon() + ' ' + wave.status.value[:8]:^10}│{agents:15}│{wave.progress:>5.0f}%{' '*4}│")
    
    print("└" + "─" * 8 + "┴" + "─" * 20 + "┴" + "─" * 10 + "┴" + "─" * 15 + "┴" + "─" * 10 + "┘")
    print(f"\nTotal: {len(waves)} waves")

def cmd_wave_show(args):
    """显示 Wave 详情"""
    wave = wave_manager.get_wave(args.wave_id)
    if not wave:
        print(f"❌ Wave {args.wave_id} not found.")
        return
    
    print()
    print(f"🌊 {wave.id}: {wave.name}")
    print("=" * 50)
    print(f"Status:     {wave.get_status_icon()} {wave.status.value} ({wave.progress:.0f}%)")
    print(f"Priority:   {wave.get_priority_icon()} {wave.priority.value}")
    print(f"Agents:     {', '.join(wave.agents)}")
    print(f"Created:    {wave.created_at.strftime('%Y-%m-%d %H:%M')}")
    
    if wave.started_at:
        print(f"Started:    {wave.started_at.strftime('%Y-%m-%d %H:%M')}")
    
    if wave.completed_at:
        print(f"Completed:  {wave.completed_at.strftime('%Y-%m-%d %H:%M')}")
    
    if wave.deadline:
        overdue = " 🔴 OVERDUE" if wave.is_overdue() else ""
        print(f"Deadline:   {wave.deadline.strftime('%Y-%m-%d %H:%M')}{overdue}")
    
    duration = wave.get_duration()
    if duration:
        print(f"Duration:   {duration}")
    
    # 进度条
    print()
    print("Progress:")
    filled = int(wave.progress / 5)
    bar = "█" * filled + "░" * (20 - filled)
    print(f"  [{bar}] {wave.progress:.0f}%")
    
    # 最近事件
    if wave.events:
        print()
        print("Recent Events:")
        for event in wave.events[-5:]:
            ts = event['timestamp'][:19] if len(event['timestamp']) > 19 else event['timestamp']
            print(f"  [{ts}] {event['agent']}: {event['message']}")
    
    print()

def cmd_wave_update(args):
    """更新 Wave"""
    wave = wave_manager.get_wave(args.wave_id)
    if not wave:
        print(f"❌ Wave {args.wave_id} not found.")
        return
    
    if args.progress is not None:
        wave.update_progress(args.progress, args.agent or "system")
    
    wave_manager.update_wave(wave)
    print(f"✅ Wave {args.wave_id} updated.")

def cmd_wave_complete(args):
    """完成 Wave"""
    wave = wave_manager.get_wave(args.wave_id)
    if not wave:
        print(f"❌ Wave {args.wave_id} not found.")
        return
    
    wave.complete(success=not args.fail)
    wave_manager.update_wave(wave)
    status = "completed" if not args.fail else "failed"
    print(f"✅ Wave {args.wave_id} marked as {status}.")

def cmd_wave_cancel(args):
    """取消 Wave"""
    wave = wave_manager.get_wave(args.wave_id)
    if not wave:
        print(f"❌ Wave {args.wave_id} not found.")
        return
    
    wave.cancel()
    wave_manager.update_wave(wave)
    print(f"✅ Wave {args.wave_id} cancelled.")

def cmd_wave_delete(args):
    """删除 Wave"""
    if wave_manager.delete_wave(args.wave_id):
        print(f"✅ Wave {args.wave_id} deleted.")
    else:
        print(f"❌ Wave {args.wave_id} not found.")

# ============ Config 命令 ============
def cmd_config_init(args):
    """初始化配置"""
    default_config = """# Wave-Haven Configuration
system:
  base_path: ~/.openclaw
  log_level: INFO

wave:
  enabled: true
  max_concurrent_waves: 10
  default_timeout: 3600
  port: 8000

haven:
  enabled: true
  memory_layers: 4
  auto_optimize: true
  cache_size: 100MB

agents:
  nova: {enabled: true, role: coordinator}
  luna: {enabled: true, role: memory_keeper}
  dreamnova: {enabled: true, role: explorer}
  kiki: {enabled: true, role: optimizer}
  coco: {enabled: true, role: executor}
"""
    
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, 'w') as f:
        f.write(default_config)
    
    print(f"✅ Configuration initialized at {CONFIG_PATH}")

def cmd_config_show(args):
    """显示配置"""
    if CONFIG_PATH.exists():
        with open(CONFIG_PATH) as f:
            print(f.read())
    else:
        print("⚠️ Configuration not found. Run 'wave-haven config init' first.")

def cmd_start(args):
    """启动系统"""
    if args.wave or not args.haven:
        print("🌊 Starting Wave System...")
        print("  ✓ Wave Manager")
        print("  ✓ Event Bus")
    
    if args.haven or not args.wave:
        print("🏝️ Starting Haven System...")
        print("  ✓ TagMemo")
        print("  ✓ Knowledge Flow")
    
    print("\n🚀 Wave-Haven is running!")

def cmd_stop(args):
    """停止系统"""
    print("🛑 Stopping Wave-Haven...")
    print("✅ Stopped")

# ============ Haven 命令 (第二阶段) ============
def cmd_haven_search(args):
    """Haven 知识搜索"""
    try:
        from haven_knowledge import HavenKnowledgeManager
        haven = HavenKnowledgeManager()
        results = haven.search(args.query, top_k=args.limit)
        
        if not results:
            print(f"🔍 No results found for '{args.query}'")
            return
        
        print(f"🔍 Search Results for '{args.query}' ({len(results)} found)")
        print("=" * 60)
        
        for i, r in enumerate(results, 1):
            print(f"\n{i}. [{r['score']:.0f}% match] {r['title']}")
            print(f"   📁 {r['file']}")
            print(f"   📝 {r['preview']}")
            if r['tags']:
                print(f"   🏷️  {' '.join(r['tags'])}")
            print(f"   📅 Modified: {r['modified']}")
        
        print()
        
    except Exception as e:
        print(f"❌ Search error: {e}")

def cmd_haven_stats(args):
    """Haven 统计信息"""
    try:
        from haven_knowledge import HavenKnowledgeManager
        haven = HavenKnowledgeManager()
        stats = haven.get_stats()
        
        print("📊 Haven Knowledge Statistics")
        print("=" * 40)
        print(f"Total Memories:     {stats['total_memories']}")
        print(f"Storage Size:       {stats['total_storage_mb']:.2f} MB")
        print(f"Recent (7 days):    {stats['recent_7days']}")
        print(f"Recent (30 days):   {stats['recent_30days']}")
        
        if stats['by_type']:
            print("\nBy Type:")
            for ext, count in sorted(stats['by_type'].items(), key=lambda x: -x[1])[:5]:
                print(f"  {ext or 'no_ext'}: {count}")
        
        if stats['top_tags']:
            print("\nTop Tags:")
            for tag, count in stats['top_tags'][:5]:
                print(f"  {tag}: {count}")
        
        print()
        
    except Exception as e:
        print(f"❌ Stats error: {e}")

def cmd_haven_recent(args):
    """Haven 最近知识"""
    try:
        from haven_knowledge import HavenKnowledgeManager
        haven = HavenKnowledgeManager()
        recent = haven.get_recent(days=args.days, limit=args.limit)
        
        if not recent:
            print(f"📭 No recent knowledge in the last {args.days} days.")
            return
        
        print(f"📚 Recent Knowledge (last {args.days} days)")
        print("=" * 60)
        
        for item in recent:
            print(f"\n📄 {item['title']}")
            print(f"   📁 {item['file']}")
            print(f"   📅 {item['modified']}")
            if item['tags']:
                print(f"   🏷️  {' '.join(item['tags'])}")
        
        print()
        
    except Exception as e:
        print(f"❌ Recent error: {e}")

def main():
    parser = argparse.ArgumentParser(
        description='Wave-Haven: Multi-Agent Task Orchestration & Knowledge Management',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  status              Show system status
  wave create         Create new wave
  wave list           List waves
  wave show           Show wave details
  wave update         Update wave progress
  wave complete       Complete wave
  wave cancel         Cancel wave
  wave delete         Delete wave
  haven search        Search knowledge
  haven stats         Show knowledge statistics
  haven recent        Show recent knowledge
  config init         Initialize configuration
  config show         Show configuration
  start               Start systems
  stop                Stop systems

Examples:
  wave-haven status
  wave-haven wave create "分析数据" --agents nova,luna --priority high
  wave-haven wave list
  wave-haven wave show W001
  wave-haven haven search "project requirements"
  wave-haven haven stats
        """
    )
    
    parser.add_argument('--version', action='version', version='%(prog)s 2.1.0')
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # status 命令
    status_parser = subparsers.add_parser('status', help='Show system status')
    status_parser.add_argument('--json', action='store_true', help='JSON output')
    status_parser.set_defaults(func=cmd_status)
    
    # wave 命令组
    wave_parser = subparsers.add_parser('wave', help='Wave management')
    wave_subparsers = wave_parser.add_subparsers(dest='wave_cmd', help='Wave commands')
    
    # wave create
    wave_create_parser = wave_subparsers.add_parser('create', help='Create new wave')
    wave_create_parser.add_argument('name', help='Wave name')
    wave_create_parser.add_argument('--description', '-d', help='Wave description')
    wave_create_parser.add_argument('--agents', '-a', help='Agents (comma-separated)')
    wave_create_parser.add_argument('--priority', '-p', default='medium', 
                                   choices=['low', 'medium', 'high', 'urgent'],
                                   help='Wave priority')
    wave_create_parser.add_argument('--deadline', help='Deadline (ISO format: 2026-03-10T23:59:00)')
    wave_create_parser.set_defaults(func=cmd_wave_create)
    
    # wave list
    wave_list_parser = wave_subparsers.add_parser('list', help='List waves')
    wave_list_parser.add_argument('--status', '-s', help='Filter by status')
    wave_list_parser.add_argument('--agent', help='Filter by agent')
    wave_list_parser.add_argument('--limit', '-n', type=int, default=100, help='Limit results')
    wave_list_parser.set_defaults(func=cmd_wave_list)
    
    # wave show
    wave_show_parser = wave_subparsers.add_parser('show', help='Show wave details')
    wave_show_parser.add_argument('wave_id', help='Wave ID')
    wave_show_parser.set_defaults(func=cmd_wave_show)
    
    # wave update
    wave_update_parser = wave_subparsers.add_parser('update', help='Update wave progress')
    wave_update_parser.add_argument('wave_id', help='Wave ID')
    wave_update_parser.add_argument('--progress', type=float, help='Progress (0-100)')
    wave_update_parser.add_argument('--agent', help='Agent name')
    wave_update_parser.set_defaults(func=cmd_wave_update)
    
    # wave complete
    wave_complete_parser = wave_subparsers.add_parser('complete', help='Complete wave')
    wave_complete_parser.add_argument('wave_id', help='Wave ID')
    wave_complete_parser.add_argument('--fail', action='store_true', help='Mark as failed')
    wave_complete_parser.set_defaults(func=cmd_wave_complete)
    
    # wave cancel
    wave_cancel_parser = wave_subparsers.add_parser('cancel', help='Cancel wave')
    wave_cancel_parser.add_argument('wave_id', help='Wave ID')
    wave_cancel_parser.set_defaults(func=cmd_wave_cancel)
    
    # wave delete
    wave_delete_parser = wave_subparsers.add_parser('delete', help='Delete wave')
    wave_delete_parser.add_argument('wave_id', help='Wave ID')
    wave_delete_parser.set_defaults(func=cmd_wave_delete)
    
    # config 命令
    config_parser = subparsers.add_parser('config', help='Configuration management')
    config_subparsers = config_parser.add_subparsers(dest='config_cmd')
    
    config_init_parser = config_subparsers.add_parser('init', help='Initialize config')
    config_init_parser.set_defaults(func=cmd_config_init)
    
    config_show_parser = config_subparsers.add_parser('show', help='Show config')
    config_show_parser.set_defaults(func=cmd_config_show)
    
    # start 命令
    start_parser = subparsers.add_parser('start', help='Start systems')
    start_parser.add_argument('--wave', action='store_true', help='Start Wave only')
    start_parser.add_argument('--haven', action='store_true', help='Start Haven only')
    start_parser.set_defaults(func=cmd_start)
    
    # stop 命令
    stop_parser = subparsers.add_parser('stop', help='Stop systems')
    stop_parser.add_argument('--wave', action='store_true', help='Stop Wave only')
    stop_parser.add_argument('--haven', action='store_true', help='Stop Haven only')
    stop_parser.set_defaults(func=cmd_stop)
    
    # haven 命令组 (第二阶段)
    haven_parser = subparsers.add_parser('haven', help='Haven knowledge management')
    haven_subparsers = haven_parser.add_subparsers(dest='haven_cmd', help='Haven commands')
    
    # haven search
    haven_search_parser = haven_subparsers.add_parser('search', help='Search knowledge')
    haven_search_parser.add_argument('query', help='Search query')
    haven_search_parser.add_argument('--limit', '-n', type=int, default=10, help='Limit results')
    haven_search_parser.set_defaults(func=cmd_haven_search)
    
    # haven stats
    haven_stats_parser = haven_subparsers.add_parser('stats', help='Show knowledge statistics')
    haven_stats_parser.set_defaults(func=cmd_haven_stats)
    
    # haven recent
    haven_recent_parser = haven_subparsers.add_parser('recent', help='Show recent knowledge')
    haven_recent_parser.add_argument('--days', '-d', type=int, default=7, help='Days to look back')
    haven_recent_parser.add_argument('--limit', '-n', type=int, default=20, help='Limit results')
    haven_recent_parser.set_defaults(func=cmd_haven_recent)
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 0
    
    if hasattr(args, 'func'):
        args.func(args)
    
    return 0

if __name__ == '__main__':
    sys.exit(main())
